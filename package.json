{
  "name": "background-agent-adapter",
  "description": "Pluggable agent adapter layer for background coding agents. Swap coding agents by implementing 13 methods and setting one env var.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Goober-Codes/background-agent-adapter"
  },
  "author": "Alden Myers",
  "keywords": [
    "background-agent",
    "coding-agent",
    "adapter",
    "pluggable",
    "sandbox",
    "ai-agent"
  ],
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "test:scripts": "node --experimental-strip-types --test scripts/*.test.ts",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "check:daytona": "node --experimental-strip-types scripts/check-daytona-auth.ts",
    "check:daytona:live": "node --experimental-strip-types scripts/daytona-live-smoke.ts --create-sandbox",
    "check:session:live": "node --experimental-strip-types scripts/session-live-smoke.ts",
    "daytona:snapshot": "node --experimental-strip-types scripts/daytona-snapshot.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "prepare": "node -e \"if (process.env.CI) process.exit(0)\" && husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "undici": "^7.24.0",
    "cloudflare": "^6.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,yaml,yml,css}": [
      "prettier --write"
    ],
    "packages/modal-infra/**/*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  }
}
